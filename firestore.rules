rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasBaseRankingFields() {
      return request.resource.data.keys().hasOnly([
        'appVersion',
        'createdAt',
        'createdAtLocal',
        'elapsedMs',
        'gradeLabel',
        'gradeSymbol',
        'levelId',
        'levelLabel',
        'mistakes',
        'nickname',
        'operationId',
        'operationLabel',
        'questionCount',
        'rankSort',
        'resultId',
        'taskId'
      ]);
    }

    function validRanking(operationId, levelId, taskId) {
      return hasBaseRankingFields()
        && request.resource.data.operationId == operationId
        && request.resource.data.levelId == levelId
        && request.resource.data.taskId == taskId
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() <= 12
        && request.resource.data.elapsedMs is number
        && request.resource.data.elapsedMs >= 0
        && request.resource.data.mistakes is number
        && request.resource.data.mistakes >= 0
        && request.resource.data.rankSort is number;
    }

    function validResult() {
      return request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() <= 12
        && request.resource.data.nicknameKey is string
        && request.resource.data.operationId is string
        && request.resource.data.taskId is string
        && request.resource.data.elapsedMs is number
        && request.resource.data.elapsedMs >= 0
        && request.resource.data.mistakes is number
        && request.resource.data.mistakes >= 0
        && request.resource.data.questionCount is number
        && request.resource.data.questionCount > 0
        && request.resource.data.questionStats is list
        && request.resource.data.questionStats.size() <= 40;
    }

    function validRankingBoardTask(boardId, operationId, levelId, taskId) {
      return (boardId == 'addition_1' && operationId == 'addition' && levelId == '1' && taskId == 'addition:1')
        || (boardId == 'addition_2' && operationId == 'addition' && levelId == '2' && taskId == 'addition:2')
        || (boardId == 'addition_3' && operationId == 'addition' && levelId == '3' && taskId == 'addition:3')
        || (boardId == 'addition_4' && operationId == 'addition' && levelId == '4' && taskId == 'addition:4')
        || (boardId == 'addition_5' && operationId == 'addition' && levelId == '5' && taskId == 'addition:5')
        || (boardId == 'addition_6' && operationId == 'addition' && levelId == '6' && taskId == 'addition:6')
        || (boardId == 'addition_7' && operationId == 'addition' && levelId == '7' && taskId == 'addition:7')
        || (boardId == 'addition_8' && operationId == 'addition' && levelId == '8' && taskId == 'addition:8')
        || (boardId == 'addition_9' && operationId == 'addition' && levelId == '9' && taskId == 'addition:9')
        || (boardId == 'addition_10' && operationId == 'addition' && levelId == '10' && taskId == 'addition:10')
        || (boardId == 'addition_11' && operationId == 'addition' && levelId == '11' && taskId == 'addition:11')
        || (boardId == 'subtraction_1' && operationId == 'subtraction' && levelId == '1' && taskId == 'subtraction:1')
        || (boardId == 'subtraction_2' && operationId == 'subtraction' && levelId == '2' && taskId == 'subtraction:2')
        || (boardId == 'subtraction_3' && operationId == 'subtraction' && levelId == '3' && taskId == 'subtraction:3')
        || (boardId == 'subtraction_4' && operationId == 'subtraction' && levelId == '4' && taskId == 'subtraction:4')
        || (boardId == 'subtraction_5' && operationId == 'subtraction' && levelId == '5' && taskId == 'subtraction:5')
        || (boardId == 'subtraction_6' && operationId == 'subtraction' && levelId == '6' && taskId == 'subtraction:6')
        || (boardId == 'subtraction_7' && operationId == 'subtraction' && levelId == '7' && taskId == 'subtraction:7')
        || (boardId == 'subtraction_8' && operationId == 'subtraction' && levelId == '8' && taskId == 'subtraction:8')
        || (boardId == 'subtraction_9' && operationId == 'subtraction' && levelId == '9' && taskId == 'subtraction:9')
        || (boardId == 'subtraction_10' && operationId == 'subtraction' && levelId == '10' && taskId == 'subtraction:10')
        || (boardId == 'subtraction_11' && operationId == 'subtraction' && levelId == '11' && taskId == 'subtraction:11')
        || (boardId == 'subtraction_12' && operationId == 'subtraction' && levelId == '12' && taskId == 'subtraction:12')
        || (boardId == 'multiplication_1' && operationId == 'multiplication' && levelId == '1' && taskId == 'multiplication:1')
        || (boardId == 'multiplication_2' && operationId == 'multiplication' && levelId == '2' && taskId == 'multiplication:2')
        || (boardId == 'multiplication_3' && operationId == 'multiplication' && levelId == '3' && taskId == 'multiplication:3')
        || (boardId == 'multiplication_4' && operationId == 'multiplication' && levelId == '4' && taskId == 'multiplication:4')
        || (boardId == 'multiplication_5' && operationId == 'multiplication' && levelId == '5' && taskId == 'multiplication:5')
        || (boardId == 'multiplication_6' && operationId == 'multiplication' && levelId == '6' && taskId == 'multiplication:6')
        || (boardId == 'multiplication_7' && operationId == 'multiplication' && levelId == '7' && taskId == 'multiplication:7')
        || (boardId == 'multiplication_8' && operationId == 'multiplication' && levelId == '8' && taskId == 'multiplication:8')
        || (boardId == 'division_1' && operationId == 'division' && levelId == '1' && taskId == 'division:1')
        || (boardId == 'division_2' && operationId == 'division' && levelId == '2' && taskId == 'division:2')
        || (boardId == 'division_3' && operationId == 'division' && levelId == '3' && taskId == 'division:3')
        || (boardId == 'division_4' && operationId == 'division' && levelId == '4' && taskId == 'division:4')
        || (boardId == 'division_5' && operationId == 'division' && levelId == '5' && taskId == 'division:5')
        || (boardId == 'division_6' && operationId == 'division' && levelId == '6' && taskId == 'division:6')
        || (boardId == 'division_7' && operationId == 'division' && levelId == '7' && taskId == 'division:7')
        || (boardId == 'division_8' && operationId == 'division' && levelId == '8' && taskId == 'division:8')
        || (boardId == 'division_9' && operationId == 'division' && levelId == '9' && taskId == 'division:9')
        || (boardId == 'division_10' && operationId == 'division' && levelId == '10' && taskId == 'division:10');
    }

    function validRankingBoardItem(item, operationId, levelId, taskId) {
      return item is map
        && item.keys().hasOnly([
          'appVersion',
          'createdAtLocal',
          'elapsedMs',
          'gradeLabel',
          'gradeSymbol',
          'levelId',
          'levelLabel',
          'mistakes',
          'nickname',
          'operationId',
          'operationLabel',
          'questionCount',
          'rankSort',
          'resultId',
          'taskId'
        ])
        && item.operationId == operationId
        && item.levelId == levelId
        && item.taskId == taskId
        && item.nickname is string
        && item.nickname.size() > 0
        && item.nickname.size() <= 12
        && item.elapsedMs is number
        && item.elapsedMs >= 0
        && item.mistakes is number
        && item.mistakes >= 0
        && item.rankSort is number
        && item.questionCount is number
        && item.questionCount > 0;
    }

    function validRankingBoardItems(operationId, levelId, taskId) {
      return request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 10
        && validRankingBoardItem(request.resource.data.items[0], operationId, levelId, taskId)
        && (request.resource.data.items.size() < 2 || validRankingBoardItem(request.resource.data.items[1], operationId, levelId, taskId))
        && (request.resource.data.items.size() < 3 || validRankingBoardItem(request.resource.data.items[2], operationId, levelId, taskId))
        && (request.resource.data.items.size() < 4 || validRankingBoardItem(request.resource.data.items[3], operationId, levelId, taskId))
        && (request.resource.data.items.size() < 5 || validRankingBoardItem(request.resource.data.items[4], operationId, levelId, taskId))
        && (request.resource.data.items.size() < 6 || validRankingBoardItem(request.resource.data.items[5], operationId, levelId, taskId))
        && (request.resource.data.items.size() < 7 || validRankingBoardItem(request.resource.data.items[6], operationId, levelId, taskId))
        && (request.resource.data.items.size() < 8 || validRankingBoardItem(request.resource.data.items[7], operationId, levelId, taskId))
        && (request.resource.data.items.size() < 9 || validRankingBoardItem(request.resource.data.items[8], operationId, levelId, taskId))
        && (request.resource.data.items.size() < 10 || validRankingBoardItem(request.resource.data.items[9], operationId, levelId, taskId));
    }

    function validRankingBoard(boardId) {
      return request.resource.data.keys().hasOnly([
          'appVersion',
          'items',
          'levelId',
          'levelLabel',
          'operationId',
          'operationLabel',
          'taskId',
          'updatedAt',
          'updatedAtLocal'
        ])
        && validRankingBoardTask(
          boardId,
          request.resource.data.operationId,
          request.resource.data.levelId,
          request.resource.data.taskId
        )
        && request.resource.data.updatedAt == request.time
        && request.resource.data.updatedAtLocal is string
        && validRankingBoardItems(
          request.resource.data.operationId,
          request.resource.data.levelId,
          request.resource.data.taskId
        );
    }

    match /rankingBoards/{boardId} {
      allow read: if true;
      allow create, update: if validRankingBoard(boardId);
      allow delete: if false;
    }

    match /rankings_addition_1/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '1', 'addition:1');
      allow update, delete: if false;
    }

    match /rankings_addition_2/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '2', 'addition:2');
      allow update, delete: if false;
    }

    match /rankings_addition_3/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '3', 'addition:3');
      allow update, delete: if false;
    }

    match /rankings_addition_4/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '4', 'addition:4');
      allow update, delete: if false;
    }

    match /rankings_addition_5/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '5', 'addition:5');
      allow update, delete: if false;
    }

    match /rankings_addition_6/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '6', 'addition:6');
      allow update, delete: if false;
    }

    match /rankings_addition_7/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '7', 'addition:7');
      allow update, delete: if false;
    }

    match /rankings_addition_8/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '8', 'addition:8');
      allow update, delete: if false;
    }

    match /rankings_addition_9/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '9', 'addition:9');
      allow update, delete: if false;
    }

    match /rankings_addition_10/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '10', 'addition:10');
      allow update, delete: if false;
    }

    match /rankings_addition_11/{document} {
      allow read: if true;
      allow create: if validRanking('addition', '11', 'addition:11');
      allow update, delete: if false;
    }

    match /rankings_subtraction_1/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '1', 'subtraction:1');
      allow update, delete: if false;
    }

    match /rankings_subtraction_2/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '2', 'subtraction:2');
      allow update, delete: if false;
    }

    match /rankings_subtraction_3/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '3', 'subtraction:3');
      allow update, delete: if false;
    }

    match /rankings_subtraction_4/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '4', 'subtraction:4');
      allow update, delete: if false;
    }

    match /rankings_subtraction_5/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '5', 'subtraction:5');
      allow update, delete: if false;
    }

    match /rankings_subtraction_6/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '6', 'subtraction:6');
      allow update, delete: if false;
    }

    match /rankings_subtraction_7/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '7', 'subtraction:7');
      allow update, delete: if false;
    }

    match /rankings_subtraction_8/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '8', 'subtraction:8');
      allow update, delete: if false;
    }

    match /rankings_subtraction_9/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '9', 'subtraction:9');
      allow update, delete: if false;
    }

    match /rankings_subtraction_10/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '10', 'subtraction:10');
      allow update, delete: if false;
    }

    match /rankings_subtraction_11/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '11', 'subtraction:11');
      allow update, delete: if false;
    }

    match /rankings_subtraction_12/{document} {
      allow read: if true;
      allow create: if validRanking('subtraction', '12', 'subtraction:12');
      allow update, delete: if false;
    }

    match /rankings_multiplication_1/{document} {
      allow read: if true;
      allow create: if validRanking('multiplication', '1', 'multiplication:1');
      allow update, delete: if false;
    }

    match /rankings_multiplication_2/{document} {
      allow read: if true;
      allow create: if validRanking('multiplication', '2', 'multiplication:2');
      allow update, delete: if false;
    }

    match /rankings_multiplication_3/{document} {
      allow read: if true;
      allow create: if validRanking('multiplication', '3', 'multiplication:3');
      allow update, delete: if false;
    }

    match /rankings_multiplication_4/{document} {
      allow read: if true;
      allow create: if validRanking('multiplication', '4', 'multiplication:4');
      allow update, delete: if false;
    }

    match /rankings_multiplication_5/{document} {
      allow read: if true;
      allow create: if validRanking('multiplication', '5', 'multiplication:5');
      allow update, delete: if false;
    }

    match /rankings_multiplication_6/{document} {
      allow read: if true;
      allow create: if validRanking('multiplication', '6', 'multiplication:6');
      allow update, delete: if false;
    }

    match /rankings_multiplication_7/{document} {
      allow read: if true;
      allow create: if validRanking('multiplication', '7', 'multiplication:7');
      allow update, delete: if false;
    }

    match /rankings_multiplication_8/{document} {
      allow read: if true;
      allow create: if validRanking('multiplication', '8', 'multiplication:8');
      allow update, delete: if false;
    }

    match /rankings_division_1/{document} {
      allow read: if true;
      allow create: if validRanking('division', '1', 'division:1');
      allow update, delete: if false;
    }

    match /rankings_division_2/{document} {
      allow read: if true;
      allow create: if validRanking('division', '2', 'division:2');
      allow update, delete: if false;
    }

    match /rankings_division_3/{document} {
      allow read: if true;
      allow create: if validRanking('division', '3', 'division:3');
      allow update, delete: if false;
    }

    match /rankings_division_4/{document} {
      allow read: if true;
      allow create: if validRanking('division', '4', 'division:4');
      allow update, delete: if false;
    }

    match /rankings_division_5/{document} {
      allow read: if true;
      allow create: if validRanking('division', '5', 'division:5');
      allow update, delete: if false;
    }

    match /rankings_division_6/{document} {
      allow read: if true;
      allow create: if validRanking('division', '6', 'division:6');
      allow update, delete: if false;
    }

    match /rankings_division_7/{document} {
      allow read: if true;
      allow create: if validRanking('division', '7', 'division:7');
      allow update, delete: if false;
    }

    match /rankings_division_8/{document} {
      allow read: if true;
      allow create: if validRanking('division', '8', 'division:8');
      allow update, delete: if false;
    }

    match /rankings_division_9/{document} {
      allow read: if true;
      allow create: if validRanking('division', '9', 'division:9');
      allow update, delete: if false;
    }

    match /rankings_division_10/{document} {
      allow read: if true;
      allow create: if validRanking('division', '10', 'division:10');
      allow update, delete: if false;
    }

    match /rankings_level_1/{document} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /rankings_level_2/{document} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /rankings_level_3/{document} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /rankings_level_4/{document} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /rankings_level_5/{document} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /trainingResults/{document} {
      allow create: if validResult();
      allow read, update, delete: if false;
    }
  }
}
